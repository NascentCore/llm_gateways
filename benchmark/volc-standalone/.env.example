# 复制为 .env 后修改下列变量
# cp .env.example .env

# NewAPI / PostgreSQL（务必修改默认密码）
POSTGRES_PASSWORD=123456

# 对外域名（与 Namecheap A 记录一致，勿含 https://；须解析到本机，勿与其它环境已占用的同名域名冲突）
DOMAIN=api.example.com

# Let’s Encrypt 通知邮箱
LETSENCRYPT_EMAIL=you@example.com

# Mock 上游（大 output 压测保持默认即可）
MOCK_OUTPUT_TOKENS=64
MOCK_MAX_COMPLETION_TOKENS=262144
