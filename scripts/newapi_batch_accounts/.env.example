# NewAPI 根地址（不含末尾斜杠）
NEWAPI_BASE_URL=https://your-newapi-host.example.com

# 管理员鉴权二选一：

# 方式 A：直接使用管理员 Token 与用户 ID（推荐）
NEWAPI_ADMIN_TOKEN=sk-your-admin-token
NEWAPI_ADMIN_USER_ID=1

# 方式 B：使用管理员账号密码（脚本会先登录获取 token）
# NEWAPI_ADMIN_USERNAME=admin
# NEWAPI_ADMIN_PASSWORD=your-admin-password

# 金额通过命令行必传：python create_account.py --amount 10
