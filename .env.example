# ── Gateway ────────────────────────────────────────────────────────────────────
# Gateway host/port
GATEWAY_HOST=0.0.0.0
GATEWAY_PORT=8000

# Master admin API key (used to call /admin/* endpoints)
ADMIN_API_KEY=change-me-admin-key

# SQLite database file path (relative or absolute)
DATABASE_URL=./gateway.db

# ── Provider credentials ────────────────────────────────────────────────────────
# Upstream provider base URLs (override to point at local mocks during tests)
OPENAI_BASE_URL=https://api.openai.com/v1
ANTHROPIC_BASE_URL=https://api.anthropic.com

# Set these when you want the gateway to fall back to its own provider keys
# instead of forwarding the caller's key.
# OPENAI_API_KEY=sk-...
# ANTHROPIC_API_KEY=sk-ant-...

# ── Logging ─────────────────────────────────────────────────────────────────────
LOG_LEVEL=INFO
